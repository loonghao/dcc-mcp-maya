{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "openmaya_signatures_schema",
  "title": "OpenMaya Signatures Index",
  "description": "Per-Maya-version index of OpenMaya/OpenMayaAnim/OpenMayaRender/OpenMayaUI public API signatures. Generated by tools/generate_openmaya_index.py.",
  "type": "object",
  "required": ["version", "generated_by", "generated_at", "modules"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Maya major version string, e.g. '2024'",
      "examples": ["2022", "2023", "2024", "2025"]
    },
    "generated_by": {
      "type": "string",
      "description": "Script that produced this file."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of generation."
    },
    "changelog": {
      "type": "object",
      "description": "Per-version delta relative to previous version. Key is Maya version string.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "added": { "type": "array", "items": { "type": "string" } },
          "removed": { "type": "array", "items": { "type": "string" } },
          "signature_changed": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "modules": {
      "type": "object",
      "description": "Map from module name to ClassMap.",
      "additionalProperties": {
        "$ref": "#/$defs/ClassMap"
      }
    }
  },
  "$defs": {
    "ClassMap": {
      "type": "object",
      "description": "Map from class name to ClassEntry.",
      "additionalProperties": {
        "$ref": "#/$defs/ClassEntry"
      }
    },
    "ClassEntry": {
      "type": "object",
      "required": ["kind", "doc", "methods"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["class", "enum", "function"],
          "description": "Python kind of this top-level member."
        },
        "bases": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Base class names (short, without module prefix)."
        },
        "doc": {
          "type": "string",
          "description": "One-line class docstring."
        },
        "methods": {
          "type": "object",
          "description": "Map from method name to MethodEntry.",
          "additionalProperties": {
            "$ref": "#/$defs/MethodEntry"
          }
        },
        "constants": {
          "type": "object",
          "description": "Enum-like integer constants defined on the class.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "value": { "type": "integer" },
              "doc": { "type": "string" }
            }
          }
        }
      }
    },
    "MethodEntry": {
      "type": "object",
      "required": ["signature", "doc"],
      "properties": {
        "signature": {
          "type": "string",
          "description": "Python inspect.signature() string or hand-written signature for C-extension methods.",
          "examples": ["(space: int = 4) -> MPointArray", "(*args, **kwargs)"]
        },
        "doc": {
          "type": "string",
          "description": "Method docstring (first paragraph only to keep size reasonable)."
        },
        "is_static": {
          "type": "boolean",
          "default": false
        },
        "is_class_method": {
          "type": "boolean",
          "default": false
        },
        "version_added": {
          "type": ["string", "null"],
          "description": "Maya version in which this method was introduced. null = unknown / pre-2022.",
          "examples": ["2023", "2024", null]
        },
        "version_removed": {
          "type": ["string", "null"],
          "description": "Maya version in which this method was removed. null = still present.",
          "examples": [null, "2025"]
        }
      }
    }
  }
}
